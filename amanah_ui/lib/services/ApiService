import 'dart:convert';
import 'package:http/http.dart' as http;

class ApiService {
  // If running locally, use 10.0.2.2 for Android Emulator or localhost for Web
  static const String baseUrl = "http://localhost:8080/api";

  Future<Map<String, dynamic>> uploadReceipt(String escrowId, List<int> bytes) async {
    var request = http.MultipartRequest('POST', Uri.parse('$baseUrl/escrow/upload-receipt/$escrowId'));
    request.files.add(http.MultipartFile.fromBytes('file', bytes, filename: 'receipt.jpg'));
    var response = await request.send();
    var respStr = await response.stream.bytesToString();
    return jsonDecode(respStr);
  }
}
